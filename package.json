{
  "name": "@akrym1582/azstorage-mcp-server",
  "version": "1.0.1",
  "description": "Read-only Azure Storage MCP Server for Blob, Queue, and Table Storage",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "azstorage-mcp-server": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akrym1582/azstorage-mcp-server.git"
  },
  "keywords": [
    "azure",
    "storage",
    "mcp",
    "blob",
    "queue",
    "table",
    "model-context-protocol",
    "llm",
    "ai"
  ],
  "author": "akrym1582",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/akrym1582/azstorage-mcp-server/issues"
  },
  "homepage": "https://github.com/akrym1582/azstorage-mcp-server#readme",
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@azure/storage-queue": "^12.29.0",
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
